{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "composite": true,
    "declarationDir": "dist",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "sourceMap": true
  },
  "include": ["src/**/*.ts"]
}
